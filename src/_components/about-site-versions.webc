<script webc:setup>
  const versions = [
    { range: "2020–2026", num: 7 },
    { range: "2018–2020", num: 6 },
    { range: "2014–2018", num: 5 },
    { range: "2011–2014", num: 4 },
    { range: "2009–2011", num: 3 },
    { range: "2007–2009", num: 2 },
    { range: "2006–2007", num: 1 },
  ];
</script>

<ol id="versions">
  <li webc:for="version of versions">
    <header class="meta">
