    <a :href="`https://v${version.num}.tylergaw.com`">
      <svg
        class="strokes"
        aria-hidden="true"
        xmlns="http://www.w3.org/2000/svg"
      ></svg>
      <picture>
        <source
          :srcset="`/images/about/2026/versions/v${version.num}.webp`"
          type="image/webp"
        />
        <img
          :src="`/images/about/2026/versions/v${version.num}.jpg`"
