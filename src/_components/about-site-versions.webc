          loading="lazy"
          width="650"
          height="1100"
        />
      </picture>
    </a>
  </li>
</ol>

<style webc:scoped>
  :host {
    display: block;
  }

  ol {
    display: flex;
    overflow-x: auto;
    padding-inline: var(--g-padding-h);
    padding-bottom: 1rem;
    scroll-snap-type: x mandatory;
    scroll-padding-inline: var(--g-padding-h);
  }

  @media (min-width: 1040px) {
    ol {
      --num-cols: 5;
      --g-offset-start: calc(
        var(--g-padding-h) + var(--skip-cols, 1) *
          (
            (
                100vw - 2 * var(--g-padding-h) - (var(--num-cols) - 1) *
                  var(--g-gutter)
              ) /
              var(--num-cols) + var(--g-gutter)
          )
      );
      padding-inline-start: var(--g-offset-start);
      scroll-padding-inline-start: var(--g-offset-start);
    }
  }

  @media (min-width: 1240px) {
    ol {
      --num-cols: 6;
    }
  }

  @media (min-width: 1660px) {
    ol {
      --num-cols: 10;
    }
  }

  @media (min-width: 2200px) {
    ol {
      --num-cols: 11;
      --skip-cols: 2;
    }
  }

  li {
    container-type: scroll-state;
    flex: 0 0 87%;
    min-width: 0;
    max-width: var(--g-max-4);
    scroll-snap-align: start;
  }

  a {
    color: var(--color-white);
    display: block;
    position: relative;
    text-decoration: none;

    &:hover,
    &:focus-visible {
      --border-color: var(--color-accent-primary);
      outline: none;
    }
  }

  .strokes {
    display: block;
    inset: 0;
    inset-inline: calc(var(--g-gutter) * 0.5);
    opacity: 0;
    pointer-events: none;
    position: absolute;
    z-index: 2;
  }

  li:first-child .strokes {
    inset-inline-start: 0;
  }

  li:last-child .strokes {
    inset-inline-end: 0;
  }

  a:hover .strokes,
  a:focus-visible .strokes {
    opacity: 1;
  }

  .meta {
    align-items: center;
    display: flex;
    flex-direction: column;
    justify-content: center;
    text-align: center;

    .contents {
      display: flex;
      flex-direction: column;
      padding: 0.5rem 0;

      b {
        font-family: var(--font-proto-bold);
        text-transform: uppercase;
      }

      span {
        font-family: var(--font-accent);
        font-size: var(--font-size-14);
      }
    }
  }

  .meta-detail {
    align-items: center;
    display: flex;
    column-gap: 4px;
    overflow: hidden;
    width: 100%;

    .point {
      --size: 1rem;
      border: 3px solid currentColor;
      border-radius: 1rem;
      flex: 0 0 1rem;
      height: var(--size);
      scale: 0.8;
      transform: 0.2s ease;
      width: var(--size);
    }

    .line {
      flex: 1;

      svg {
        display: block;
        width: 101%;
      }
    }
  }

  li:first-child .meta-detail .line-left,
  li:last-child .meta-detail .line-right {
    opacity: 0;
  }

  li:first-child picture {
    padding-inline-start: 0;
  }

  li:last-child picture {
    padding-inline-end: 0;
  }

  picture {
    display: block;
    filter: saturate(0) contrast(1.25);
    overflow: hidden;
    position: relative;
    max-height: 88dvh;
    padding-inline: calc(var(--g-gutter) * 0.5);

    img {
      display: block;
      height: auto;
      transition: scale 2s ease;
      width: 100%;
    }
  }

  a:hover,
  a:focus-visible {
    picture {
      filter: saturate(100%);
    }

    img {
      scale: 1.02;
    }
  }

  @container scroll-state(snapped: x) {
    .meta-detail .point {
      background-color: currentColor;
      scale: 1;
    }

    picture {
      filter: saturate(100%);
    }
  }
</style>

<script webc:bucket="components">
  initDrawStrokes("#versions a", {
    filterId: "version-warp",
    yBias: "edges",
  });
</script>
