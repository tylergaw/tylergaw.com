  <div class="abstract-container">
    <div class="graphic">
      <video
        muted
        autoplay
        playsinline
        loop
        poster="/images/home/home-abstract-01.webp"
        src="/videos/abstract-2.mp4"
        loading="lazy"
      ></video>
    </div>
  </div>
</div>

<style webc:scoped="home-contents-secondary">
  :host {
    display: flex;
    flex: 1;
    row-gap: var(--g-gutter);
  }

  .home-contents-card {
    --card-img-contrast: 1.55;
    flex: 1 1 var(--g-max-3);
    max-width: var(--max-w, var(--g-max-3));
    min-height: 15.625rem;

    & + .home-contents-card {
      margin-left: var(--g-gutter);
    }
  }

  .abstract-container {
    display: flex;
    flex: 1 0 0%;
    overflow: hidden;
    position: relative;

    .graphic {
      background: var(--color-accent-primary);
      position: absolute;
      inset: 0 0 0 var(--g-gutter);
      width: 100%;

      &::after {
        content: "";
        width: 100%;
        height: 100%;
        filter: url(#noise);
        mix-blend-mode: color-dodge;
        position: absolute;
        opacity: 0.7;
        top: 0;
        left: 0;
      }

      video {
        mix-blend-mode: luminosity;
        filter: brightness(1.2);
        object-fit: cover;
        object-position: center;
        height: 101%;
        width: 100%;
      }
    }
  }

  @media (min-width: 1860px) {
    .home-contents-card {
      --max-w: var(--g-max-4);
    }
  }
</style>
